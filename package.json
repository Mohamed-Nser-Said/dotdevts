{
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "tstl",
    "setup": "tstl && cts run ./build/setup.lua -n win1000",
    "dev": "tstl --watch",
    "mainc": "tstl && cts run ./build/main.lua",
    "maind": "tstl && cts run ./build/main.lua -n dockerWEBAPI-BLESSED",
    "main": "tstl && cts run ./build/main.lua -n win1000 --bundle",
    "webstudio:run": "node ./scripts/push-webstudio-examples.js --run --bundle",
    "webstudio:run:all": "node ./scripts/push-webstudio-examples.js --run --bundle",
    "webstudio:push": "node ./scripts/push-webstudio-examples.js",
    "webstudio:push:all": "node ./scripts/push-webstudio-examples.js",
    "verify:setfunc": "tstl && node ./scripts/verify-setfunc.js"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript-to-lua": "^1.34.0"
  }
}
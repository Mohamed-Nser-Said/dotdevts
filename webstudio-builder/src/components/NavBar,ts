import { StyleProps } from "../core/types";
import { Window } from "../core/Window";
import { HLayoutContainer } from "../layouts/HLayoutContainer";
import { Button } from "../widgets/Button";
import { Text } from "../widgets/Text";

export interface NavBarItem {
    label: string;
    name?: string;
    actionName?: string;
    url?: string;
    target?: "_self" | "_blank" | "_parent" | "_top";
    disabled?: boolean;
    style?: Partial<StyleProps>;
    onClick?: (ctx: Window) => void;
}

export interface NavBarProps {
    name?: string;
    description?: string;
    title?: string;
    items?: NavBarItem[];
    gap?: number;
    titleStyle?: Partial<StyleProps>;
    itemStyle?: Partial<StyleProps>;
}

const defaultTitleStyle: StyleProps = {
    backgroundColor: "#0f172a",
    color: "#ffffff",
    padding: "10px 16px",
    fontSize: "18px",
    fontWeight: "bold",
    textAlign: "left",
    borderRadius: "10px",
};

const defaultItemStyle: StyleProps = {
    backgroundColor: "#e2e8f0",
    color: "#0f172a",
    padding: "10px 14px",
    fontSize: "14px",
    borderRadius: "10px",
    border: "1px solid #cbd5e1",
    cursor: "pointer",
};

/**
 * Reusable navigation bar component for WebStudio pages.
 *
 * Example:
 * ```ts
 * const nav = new NavBar({
 *   title: "Operations Center",
 *   items: [
 *     { label: "Overview", actionName: "showOverview" },
 *     { label: "Docs", url: "https://inmation.com", target: "_blank" },
 *   ],
 * });
 * ```
 */
export class NavBar extends HLayoutContainer {
    constructor(props?: NavBarProps) {
        props = props || {};

        const items = props.items || [];
        const hasTitle = !!props.title;

        super({
            name: props.name || "NavBar",
            description: props.description || "Reusable navigation bar",
            columns: NavBar.buildColumns(items.length, hasTitle),
            gap: props.gap === undefined ? 1 : props.gap,
        });

        let currentCol = 1;

        if (hasTitle) {
            const title = new Text({
                name: `${props.name || "NavBar"}Title`,
                text: props.title,
                showCaption: false,
                style: {
                    ...defaultTitleStyle,
                    ...(props.titleStyle || {}),
                },
            });
            this.addWidget(title, currentCol);
            currentCol += 1;
        }

        for (const item of items) {
            const button = new Button({
                name: item.name || item.label,
                label: item.label,
                disabled: item.disabled || false,
                style: {
                    ...defaultItemStyle,
                    ...(props.itemStyle || {}),
                    ...(item.style || {}),
                },
            });

            if (item.onClick) {
                button.onClicked(item.onClick);
            } else if (item.actionName) {
                button.onClicked((ctx) => {
                    ctx.action(item.actionName as string);
                });
            } else if (item.url) {
                button.onClicked((ctx) => {
                    ctx.openLink(item.url as string, item.target);
                });
            }

            this.addWidget(button, currentCol);
            currentCol += 1;
        }
    }

    private static buildColumns(itemCount: number, hasTitle: boolean): number[] {
        const columns: number[] = [];

        if (hasTitle) {
            columns.push(itemCount > 2 ? 2 : 1);
        }

        const safeCount = Math.max(itemCount, hasTitle ? 0 : 1);
        for (let i = 0; i < safeCount; i += 1) {
            columns.push(1);
        }

        return columns.length > 0 ? columns : [1];
    }
}

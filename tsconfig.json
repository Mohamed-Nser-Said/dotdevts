{
  "$schema": "https://raw.githubusercontent.com/TypeScriptToLua/TypeScriptToLua/master/tsconfig-schema.json",
  
  "compilerOptions": {
    "moduleResolution": "Node",
    "types": [],
    "strict": true,
    "outDir": "build",
    "lib": ["ES2015", "DOM"]
  },
  "tstl": {
    "sourceMapTraceback": false,
    "luaTarget": "5.3",
    "noResolvePaths": ["dkjson", "mongo"]
  }
}